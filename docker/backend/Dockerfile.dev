FROM python:3.12-slim

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY ApiServer/requirements.txt /workspace/ApiServer/requirements.txt
RUN pip install --no-cache-dir -r /workspace/ApiServer/requirements.txt

COPY ApiServer/ /workspace/ApiServer/
COPY stage_contracts/ /workspace/stage_contracts/
COPY ReqAnalysis/ /workspace/ReqAnalysis/
COPY SolDesign/ /workspace/SolDesign/
COPY CodeGen/ /workspace/CodeGen/
COPY CodeTest/ /workspace/CodeTest/
COPY Integration/ /workspace/Integration/
COPY ReviewGate/ /workspace/ReviewGate/

EXPOSE 8000

WORKDIR /workspace/ApiServer

CMD ["python", "run.py"]
