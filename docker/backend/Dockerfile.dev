FROM python:3.12-slim

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV DELIVERAX_HOST=0.0.0.0
ENV DELIVERAX_RELOAD=false

COPY server/requirements.txt /workspace/server/requirements.txt
RUN pip install --no-cache-dir -r /workspace/server/requirements.txt

COPY stage_contracts/ /workspace/stage_contracts/
COPY server/ /workspace/server/
COPY agents/ /workspace/agents/
COPY .env /workspace/.env

EXPOSE 8000

WORKDIR /workspace/server

CMD ["python", "run.py"]
