  <diagram id="d-repairloop" name="07-RepairLoop（详）">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="rl0" />
        <mxCell id="rl1" parent="rl0" />
        <mxCell id="rl-title" value="&lt;b&gt;RepairLoop&lt;/b&gt; · RepairLoop/run.py · 编排 CodeTest 子进程 + FeedbackTriage.run_triage · 产出 pipeline_loop_summary.json" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;" vertex="1" parent="rl1">
          <mxGeometry x="40" y="16" width="900" height="32" as="geometry" />
        </mxCell>
        <mxCell id="rl-init" value="初始化&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;dx-root、max_iterations、codegen/codetest task-id、design、repo-path、workspace-dir、requirement-path、&lt;b&gt;initial-codegen-result&lt;/b&gt;；codetest_extra_args=[]；codegen_result 指向首轮 JSON&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
          <mxGeometry x="60" y="52" width="360" height="78" as="geometry" />
        </mxCell>
        <mxCell id="rl-loop" value="&lt;b&gt;for ct_round in range(max_iter)&lt;/b&gt; · 每轮先跑 CodeTest" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="60" y="148" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rl-ct" value="子进程：CodeTest/run.py&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;--codegen-result 当前指针 · --requirement · --task-id codetest · --workspace-dir CodeTest/.workspace · --force · --max-llm-calls 32 · 若有上轮反馈则附加 &lt;b&gt;--repair-feedback feedback_to_codetest.md&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
          <mxGeometry x="60" y="206" width="360" height="88" as="geometry" />
        </mxCell>
        <mxCell id="rl-gate1" value="returncode ∈ {0, 2}？&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;否则 code_test_fatal_exit&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#d6b656;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="120" y="312" width="240" height="88" as="geometry" />
        </mxCell>
        <mxCell id="rl-gate2" value="code_test_result.json 存在？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#d6b656;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="120" y="418" width="240" height="72" as="geometry" />
        </mxCell>
        <mxCell id="rl-triage" value="run_triage(result_path)&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;FeedbackTriage/triage.py：读 result+log→&lt;b&gt;_classify_failure&lt;/b&gt;→清理旧 feedback_to_*.md→写 &lt;b&gt;triage_result.json&lt;/b&gt; + 单份 &lt;b&gt;feedback_*.md&lt;/b&gt;（passed / to_codetest / to_solutiondesign / to_environment / &lt;b&gt;to_codegen&lt;/b&gt; 默认）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
          <mxGeometry x="60" y="508" width="360" height="102" as="geometry" />
        </mxCell>
        <mxCell id="rl-record" value="summary.iterations.append(&lt;br&gt;round / status / triage 字段 / paths…)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;fontSize=11;" vertex="1" parent="rl1">
          <mxGeometry x="60" y="624" width="360" height="44" as="geometry" />
        </mxCell>
        <mxCell id="rl-pass" value="CodeTest status 视为通过？&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;passed / pass / ok / success&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="120" y="684" width="240" height="88" as="geometry" />
        </mxCell>
        <mxCell id="rl-win" value="final_outcome=passed&lt;br&gt;stop_reason=code_test_passed&lt;br&gt;写 pipeline_loop_summary.json · &lt;b&gt;exit 0&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="rl1">
          <mxGeometry x="480" y="700" width="260" height="72" as="geometry" />
        </mxCell>
        <mxCell id="rl-max" value="已是本轮 max 内&lt;br&gt;最后一次尝试？&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;ct_round ≥ max_iter-1&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#d6b656;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="120" y="792" width="240" height="88" as="geometry" />
        </mxCell>
        <mxCell id="rl-failmax" value="failed · max_iterations_exhausted&lt;br&gt;写 summary · &lt;b&gt;exit 2&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="480" y="808" width="220" height="56" as="geometry" />
        </mxCell>
        <mxCell id="rl-route" value="自动修复路由？&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;读 triage：owner + failure_category&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#d6b656;align=center;" vertex="1" parent="rl1">
          <mxGeometry x="100" y="900" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="rl-cg" value="&lt;b&gt;codegen + product_code&lt;/b&gt;&lt;br&gt;需 feedback_to_codegen.md&lt;br&gt;子进程 CodeGen/run.py：&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;--design --repo-path --workspace-dir --task-id codegen &lt;b&gt;--repair-feedback&lt;/b&gt; fb_md&lt;/font&gt;&lt;br&gt;成功后 codegen_result ← CodeGen/Output/「codegen_task_id」/codegen_result.json；清空 codetest_extra_args；&lt;b&gt;continue&lt;/b&gt; 下一轮 CodeTest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
          <mxGeometry x="440" y="888" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="rl-ctfb" value="&lt;b&gt;codetest + test_design&lt;/b&gt;&lt;br&gt;需 feedback_to_codetest.md&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;codetest_extra_args = [--repair-feedback, fb_ct]；迭代记录可标 codetest_repair_scheduled；&lt;b&gt;continue&lt;/b&gt; 下一轮（仍用当前 codegen_result，改测生成/用例）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
          <mxGeometry x="440" y="1020" width="320" height="96" as="geometry" />
        </mxCell>
        <mxCell id="rl-no" value="其他 owner/category&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#555&quot;&gt;如 environment、solutiondesign、spec_ambiguous、unknown…&lt;/font&gt;&lt;br&gt;&lt;b&gt;no_auto_repair&lt;/b&gt; · 写 summary · exit 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
          <mxGeometry x="60" y="1140" width="360" height="72" as="geometry" />
        </mxCell>
        <mxCell id="rl-fatal" value="致命：exit 非法 / result 缺失 / CodeGen repair 子进程失败 / 缺少应有 feedback md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="rl1">
          <mxGeometry x="480" y="312" width="300" height="72" as="geometry" />
        </mxCell>
        <mxCell id="rl-summary" value="统一收尾：_write_summary →&lt;br&gt;CodeTest/Output/「codetest_task_id」/&lt;b&gt;pipeline_loop_summary.json&lt;/b&gt;（含 iterations、final_outcome、stop_reason）；随后 print JSON、&lt;b&gt;exit 0/2&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#36393d;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="rl1">
