<mxfile host="app.diagrams.net" modified="2026-05-03T12:00:00.000Z" agent="Cursor" version="22.1.0" type="device">
  <diagram id="d-overview" name="00-总览（六阶段 I/O）">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="ov0" />
        <mxCell id="ov1" parent="ov0" />
        <mxCell id="ov-title" value="&lt;b style=&quot;font-size:16px&quot;&gt;DeliveraX：需求分析 → 交付集成&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666&quot;&gt;下方页签含各阶段详图；&lt;b&gt;07-RepairLoop&lt;/b&gt; 为 CodeTest⇄FeedbackTriage⇄CodeGen/CodeTest 自动修复循环（RepairLoop/run.py）&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="ov1">
          <mxGeometry x="40" y="20" width="720" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ov-n1" value="&lt;b&gt;① 需求分析 · RequirementsAnalysis&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;输入&lt;/b&gt;：自然语言需求、会议纪要、产品想法（如 input.txt）&lt;br&gt;&lt;b&gt;输出&lt;/b&gt;：requirement_spec.json、requirement_prd.md、report.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="ov1">
          <mxGeometry x="80" y="90" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ov-n2" value="&lt;b&gt;② 方案设计 · SolutionDesign&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;输入&lt;/b&gt;：结构化 PRD / 需求路径；目标仓库 repo_url 或 repo_path、分支 ref&lt;br&gt;&lt;b&gt;输出&lt;/b&gt;：technical_design_*.md；仓库缓存 .workspace/repos/…" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="ov1">
          <mxGeometry x="80" y="220" width="640" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ov-n3" value="&lt;b&gt;③ 代码生成 · CodeGen&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;输入&lt;/b&gt;：技术方案 Markdown；方案阶段同一仓库上下文（任务副本内修改）&lt;br&gt;&lt;b&gt;输出&lt;/b&gt;：code_changes.diff、codegen_report.md、codegen_result.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="ov1">
          <mxGeometry x="80" y="360" width="640" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ov-n4" value="&lt;b&gt;④ 测试生成 · CodeTest&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;输入&lt;/b&gt;：codegen_result.json&lt;br&gt;&lt;b&gt;输出&lt;/b&gt;：code_test_result.json（及 test_plan / 生成用例等）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="ov1">
          <mxGeometry x="80" y="500" width="640" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ov-n5" value="&lt;b&gt;⑤ 代码评审 · CodeReview&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;输入&lt;/b&gt;：code_test_result.json（必填）；方案+diff 或 codegen_result；可选 requirement、policy&lt;br&gt;&lt;b&gt;输出&lt;/b&gt;：code_review_result.json、code_review_report.md、feedback_review.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="ov1">
          <mxGeometry x="80" y="630" width="640" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ov-n6" value="&lt;b&gt;⑥ 交付集成 · DeliveryIntegration&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;输入&lt;/b&gt;：codegen_result.json；可选测试/评审 JSON 门禁&lt;br&gt;&lt;b&gt;输出&lt;/b&gt;：final_changes.diff、change_summary.md、github_pr_body.md、delivery_integration_result.json&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;不自动 push；不重跑测试/评审&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#36393d;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="ov1">
          <mxGeometry x="80" y="770" width="640" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ov-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="ov1" source="ov-n1" target="ov-n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="ov1" source="ov-n2" target="ov-n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="ov1" source="ov-n3" target="ov-n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="ov1" source="ov-n4" target="ov-n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="ov1" source="ov-n5" target="ov-n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ov-repair" value="可选 RepairLoop：测试失败 → 反馈 → CodeGen" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;dashPattern=8 8;html=1;endArrow=block;endFill=1;strokeColor=#999999;fontSize=10;" edge="1" parent="ov1" source="ov-n4" target="ov-n3">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="760" y="550" /><mxPoint x="760" y="415" /></Array></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
