# ============================================================
# DeliveraX — LLM Provider API Keys
# ============================================================
# Copy this file to .env in the same directory:
#   cp .env.example .env
#
# .env is in .gitignore — it will NEVER be committed to Git.
#
# You only need ONE of the following keys for DeliveraX to work.
# DeepSeek and Qwen are the cheapest / easiest to get started with.
# ============================================================

# DeepSeek (推荐 — 便宜且效果好)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Qwen / 通义千问 (阿里云 — 国内首选)
# Get your key at: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-your-qwen-key-here

# OpenAI (optional)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================
# Optional: DeliveraX settings
# ============================================================
# DELIVERAX_HOST=127.0.0.1
# DELIVERAX_PORT=8000
# DELIVERAX_RELOAD=true
# DELIVERAX_REPO_ROOT=/absolute/path/to/your/target/repo
# DELIVERAX_ARTIFACTS_ROOT=/absolute/path/to/artifacts
